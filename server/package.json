{
  "name": "heirloom-speech-analysis-server",
  "version": "1.0.0",
  "description": "Express backend for Heirloom Speech Analysis",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "build": "npm ci && npm run build:ts",
    "build:ts": "npx tsc --skipLibCheck",
    "dev": "npm run build:ts && npm run start:dev",
    "start:dev": "node dist/index.js",
    "watch": "npx tsc --skipLibCheck --watch & npm run start:dev",
    "dev:fast": "ts-node-dev --respawn --transpile-only --ignore-watch node_modules index.ts",
    "dev:nodemon": "nodemon",
    "postinstall": "node -e \"console.log('Postinstall: Checking module resolution...')\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["express", "backend", "speech-analysis"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "@supabase/supabase-js": "^2.38.0",
    "multer": "^1.4.5-lts.1",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "google-auth-library": "^8.7.0",
    "axios": "^1.6.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "@types/multer": "^1.4.11",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "typescript": "^5.3.2"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1"
  },
  "engines": {
    "node": "18.x"
  },
  "overrides": {
    "readable-stream": "^4.4.2"
  }
}
